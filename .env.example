# Copy this file to .env (which is gitignored) and fill in real values.
# Used by Playwright tests to authenticate against Auth0 via Password Grant.
# See e2e/global.setup.ts for how these are consumed.

# Test user email (matches the user provisioned in Auth0 for E2E).
SCOUT_TEST_EMAIL=scout-e2e@intelligentbuildings.com

# Test user password. Get the value from a secure channel (password manager,
# 1Password, etc.) — never commit this. Same value goes into GitHub Actions
# secrets under SCOUT_TEST_PASSWORD for CI.
SCOUT_TEST_PASSWORD=

# Optional: override the URL tests run against. Defaults to
# https://ibscout.netlify.app (production). For local testing on the feature
# branch's deploy preview, set to:
#   https://deploy-preview-8--ibscout.netlify.app
# PLAYWRIGHT_BASE_URL=
